# SPK Bot - Environment Configuration
# Copy this file to .env and fill in your actual values.
#
# ╔══════════════════════════════════════════════════════════╗
# ║  DUAL ENVIRONMENT SETUP                                 ║
# ║  🏠 Home Desktop  → main branch → SPK Mobile Bot token  ║
# ║  🏢 Office Notebook → dev branch → SPK Dev Bot token    ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Each environment uses its OWN Telegram bot token.      ║
# ║  Never share the same token across both environments!   ║
# ╚══════════════════════════════════════════════════════════╝

# Required: Telegram Bot Token (from BotFather)
# 🏠 Home (main branch): Use SPK Mobile Bot token
# 🏢 Office (dev branch): Use SPK Dev Bot token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Gemini AI (stock analysis, etc.)
GEMINI_API_KEY=your_gemini_api_key

# Optional: Brave Search API
BRAVE_API_KEY=
